# GoHighLevel MCP Server Configuration
# =====================================

# REQUIRED: Your Private Integration Token from GHL
# Go to: Settings → Private Integrations → Create New Integration
GHL_API_KEY=your_private_integration_token_here

# REQUIRED: Your GHL Location ID (Sub-account ID)
# Found in: Settings → Company → Locations, or in the URL when viewing a sub-account
GHL_LOCATION_ID=your_location_id_here

# OPTIONAL: Base URL (default is correct for most users)
GHL_BASE_URL=https://services.leadconnectorhq.com

# OPTIONAL: API Version header
GHL_API_VERSION=2021-07-28

# OPTIONAL: Server configuration
TRANSPORT=http
PORT=3001
LOG_LEVEL=info
